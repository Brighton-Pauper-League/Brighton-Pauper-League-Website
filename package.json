{
  "name": "brighton-pauper-league",
  "version": "1.0.0",
  "private": true,
  "description": "Brighton Pauper League website - monorepo",
  "scripts": {
    "dev:studio": "cd studio && npm run dev",
    "dev:web": "cd web && npm run dev",
