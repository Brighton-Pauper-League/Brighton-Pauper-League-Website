# Sanity Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=sdzciglo
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# Public site URL — used for metadata, Open Graph, sitemap, and robots.
# Set per-environment (e.g. a Vercel preview URL); production falls back to the domain.
NEXT_PUBLIC_SITE_URL=https://brightonpauperleague.com

# Shared secret for the Sanity → /api/revalidate webhook (on-demand revalidation).
# Must match the secret configured on the webhook in sanity.io/manage.
SANITY_REVALIDATE_SECRET=your-webhook-secret-here

# Sanity API Token — SERVER ONLY (Get from: https://www.sanity.io/manage)
# Create a token with "Viewer" role for read access.
# Do NOT expose this via a NEXT_PUBLIC_* variable — it is a secret credential
# and NEXT_PUBLIC_* values are bundled into client-side JS.
SANITY_API_READ_TOKEN=your-read-token-here
